{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/ai-rewrite.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/staff=1",
      "destination": "/staff.html"
    },
    {
      "source": "/staff",
      "destination": "/staff.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
